---
import Staff from "./Staff.astro";
import MusicGlyph from "./MusicGlyph.astro";
const { lang = "el" } = Astro.props;
---

<footer class="sp-footer">
  <Staff height={48} notes={["𝄞", "♩", "♪", "♫", "𝄐"]} />

  <div class="container">
    <div class="sp-colophon">
      <div class="sp-colophon-brand">
        <div class="wordmark" style="font-size:3.5rem">
          <MusicGlyph glyph="treble" size="3.2rem" color="#9B2A1F" /> sky<b>pulse</b>
        </div>
        <p class="display-italic sp-colophon-tag">— the sound of your movement.</p>
      </div>

      <div class="sp-colophon-col">
        <span class="eyebrow">Contact</span>
        <a href="mailto:info@sky-pulse.gr">info@sky-pulse.gr</a>
        <a href="tel:+306932669999">+30 6932 669999</a>
      </div>

      <div class="sp-colophon-col">
        <span class="eyebrow">Index</span>
        <a href="#work">Selected work</a>
        <a href="#process">Process</a>
        <a href="#studio">Studio</a>
        <a href="#contact">Booking</a>
      </div>

      <div class="sp-colophon-col">
        <span class="eyebrow">Colophon</span>
        <span>Set in Newsreader &amp; Geist</span>
        <span>Athens · Greece</span>
        <a href="/politiki-aporritou/">Privacy Policy</a>
      </div>
    </div>

    <hr class="rule rule-ink" />
    <div class="sp-colophon-foot">
      <span class="mono">© MMXXVI · sky pulse</span>
      <span class="mono">{lang === "el" ? "Εκ του μηδενός" : "Composed from silence"}</span>
      <span class="mono">[37.9838 N · 23.7275 E]</span>
    </div>
  </div>
</footer>

<style>
  .sp-footer { padding: 6rem 0 3rem; background: #F1ECDE; }
  .sp-colophon {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding: 4rem 0;
  }
  @media (min-width: 900px) {
    .sp-colophon { grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; }
  }
  .sp-colophon-brand { display: flex; flex-direction: column; gap: 1rem; }
  .sp-colophon-tag { font-size: 1.5rem; color: #5C564A; max-width: 22ch; }
  .sp-colophon-col { display: flex; flex-direction: column; gap: 0.85rem; }
  .sp-colophon-col a, .sp-colophon-col span:not(.eyebrow) {
    color: #0E0E0E;
    text-decoration: none;
    font-family: "Newsreader", serif;
    font-size: 1.05rem;
    font-weight: 400;
    transition: color .3s ease;
  }
  .sp-colophon-col a:hover { color: #9B2A1F; }
  .sp-colophon-foot {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 2rem;
    color: #5C564A;
  }
</style>
