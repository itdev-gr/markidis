---
import Staff from "./Staff.astro";
import { pick, localeUrl, type Lang } from "../i18n/strings";

interface Props { lang?: Lang; }
const { lang = "el" } = Astro.props;
const t = pick(lang);
const u = (p: string) => localeUrl(lang, p);
---

<footer class="sp-footer">
  <Staff height={48} notes={["𝄞", "♩", "♪", "♫", "𝄐"]} />

  <div class="container">
    <div class="sp-colophon">
      <div class="sp-colophon-brand">
        <img class="sp-colophon-logo" src="/media/logo.svg" alt="Sky Pulse" width="320" height="104" />
        <p class="display-italic sp-colophon-tag">{t.footer.tag}</p>
      </div>

      <div class="sp-colophon-col">
        <span class="eyebrow">{t.footer.contact}</span>
        <a href={`mailto:${t.common.email}`}>{t.common.email}</a>
        <a href={t.common.phoneHref}>{t.common.phone}</a>
      </div>

      <div class="sp-colophon-col">
        <span class="eyebrow">{t.footer.index}</span>
        <a href={u("/work")}>{t.footer.linkWork}</a>
        <a href={u("/process")}>{t.footer.linkProcess}</a>
        <a href={u("/studio")}>{t.footer.linkStudio}</a>
        <a href={u("/contact")}>{t.footer.linkBooking}</a>
      </div>

      <div class="sp-colophon-col">
        <span class="eyebrow">{t.footer.colophon}</span>
        <span>{t.footer.setIn}</span>
        <span>{t.footer.location}</span>
        <a href={t.footer.privacyHref}>{t.footer.privacy}</a>
      </div>
    </div>

    <hr class="rule rule-ink" />
    <div class="sp-colophon-foot">
      <span class="mono">{t.footer.copy}</span>
      <span class="mono">{t.footer.composedFrom}</span>
      <span class="mono">{t.footer.coords}</span>
    </div>
  </div>
</footer>

<style>
  .sp-footer { padding: 6rem 0 3rem; background: #F1ECDE; }
  .sp-colophon {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding: 4rem 0;
  }
  @media (min-width: 900px) {
    .sp-colophon { grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; }
  }
  .sp-colophon-brand { display: flex; flex-direction: column; gap: 1.25rem; }
  .sp-colophon-logo { height: 4.5rem; width: auto; display: block; }
  .sp-colophon-tag { font-size: 1.5rem; color: #6C6E70; max-width: 22ch; }
  .sp-colophon-col { display: flex; flex-direction: column; gap: 0.85rem; }
  .sp-colophon-col a, .sp-colophon-col span:not(.eyebrow) {
    color: #0E0E0E;
    text-decoration: none;
    font-family: "Newsreader", serif;
    font-size: 1.05rem;
    font-weight: 400;
    transition: color .3s ease;
  }
  .sp-colophon-col a:hover { color: #6C6E70; }
  .sp-colophon-foot {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 2rem;
    color: #6C6E70;
  }
</style>
