---
import Staff from "../Staff.astro";
import { pick, type Lang } from "../../i18n/strings";

interface Props { lang?: Lang; }
const { lang = "el" } = Astro.props;
const t = pick(lang);
const s = t.cta;
const alertText = s.successAlert.replace(/'/g, "\\'");
---

<section id="contact" class="section cta">
  <div class="container">
    <p class="cta-sub display-italic" data-reveal>
      {s.sub}
    </p>

    <Staff height={32} notes={["𝄞", "♩", "♪", "♫", "𝄐"]} class="cta-staff" />

    <div class="cta-grid">
      <form class="cta-form" data-reveal onsubmit={`event.preventDefault(); alert('${alertText}');`}>
        <div class="field">
          <label for="name">{s.fields.name}</label>
          <input id="name" name="name" required autocomplete="name" />
        </div>
        <div class="field">
          <label for="email">{s.fields.email}</label>
          <input id="email" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="field">
          <label for="sport">{s.fields.sport}</label>
          <input id="sport" name="sport" placeholder={s.fields.sportPh} required />
        </div>
        <div class="field">
          <label for="length">{s.fields.length}</label>
          <input id="length" name="length" placeholder={s.fields.lengthPh} required />
        </div>
        <div class="field full">
          <label for="brief">{s.fields.brief}</label>
          <textarea id="brief" name="brief" rows="4" placeholder={s.fields.briefPh}></textarea>
        </div>
        <button class="sp-btn sp-btn-primary" data-magnetic="0.3" type="submit">
          <span>{s.submit}</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12m0 0L8 2m5 5L8 12" stroke="currentColor" stroke-width="1.4"/></svg>
        </button>
      </form>

      <aside class="cta-aside" data-reveal>
        <div class="cta-row">
          <span class="eyebrow">{s.emailLabel}</span>
          <a href={`mailto:${t.common.email}`} class="cta-val display-italic">{t.common.email}</a>
        </div>
        <hr class="rule" />
        <div class="cta-row">
          <span class="eyebrow">{s.phoneLabel}</span>
          <a href={t.common.phoneHref} class="cta-val display-italic">{t.common.phone}</a>
        </div>
        <hr class="rule" />
        <div class="cta-row">
          <span class="eyebrow">{s.responseLabel}</span>
          <span class="cta-val display-italic">{s.responseValue}</span>
        </div>
        <hr class="rule" />
        <div class="cta-row">
          <span class="eyebrow">{s.hoursLabel}</span>
          <span class="cta-val display-italic">{s.hoursValue}</span>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .cta-title { font-size: clamp(4rem, 12vw, 12rem); margin: 2rem 0 1.5rem; line-height: 0.9; color: #1A1A2E; }
  .cta-sub { font-size: clamp(1.4rem, 2.2vw, 2.2rem); color: #8E8E9F; max-width: 32ch; margin: 0 0 2rem; }
  .cta-staff { margin: 1rem 0 3rem; }
  .cta-grid { display: grid; grid-template-columns: 1fr; gap: 4rem; align-items: start; }
  @media (min-width: 1000px) { .cta-grid { grid-template-columns: 1.3fr 1fr; gap: 5rem; } }

  .cta-form { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .cta-form .field.full { grid-column: 1 / -1; }
  .cta-form label {
    display: block;
    color: #8E8E9F;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .cta-form input,
  .cta-form textarea {
    width: 100%;
    background: transparent;
    color: #1A1A2E;
    border: 0;
    border-bottom: 1px solid #1A1A2E;
    padding: 0.75rem 0;
    font-family: "Newsreader", serif;
    font-size: 1.1rem;
    font-weight: 400;
    outline: none;
    transition: border-color .3s ease;
    resize: vertical;
  }
  .cta-form input:focus,
  .cta-form textarea:focus { border-color: #1A1A2E; border-bottom-width: 2px; }
  .cta-form button { grid-column: 1 / -1; justify-self: start; margin-top: 1rem; }

  .cta-aside { display: flex; flex-direction: column; gap: 1.5rem; }
  .cta-row { display: flex; flex-direction: column; gap: 0.3rem; }
  .cta-val { font-size: clamp(1.5rem, 2.5vw, 2rem); color: #1A1A2E; text-decoration: none; }
  a.cta-val:hover { color: #8E8E9F; }
</style>
