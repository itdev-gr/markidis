---
import Staff from "../Staff.astro";
import MusicGlyph from "../MusicGlyph.astro";
---

<section id="contact" class="section cta">
  <div class="container">
    <h2 class="cta-title display" data-split>Score your next routine.</h2>

    <p class="cta-sub display-italic" data-reveal>
      Tell us the athlete, the sport, the deadline. We answer in 24 hours.
    </p>

    <Staff height={32} notes={["𝄞", "♩", "♪", "♫", "𝄐"]} class="cta-staff" />

    <div class="cta-grid">
      <form class="cta-form" data-reveal onsubmit="event.preventDefault(); alert('Thank you. We will be in touch within 24 hours.');">
        <div class="field">
          <label for="name">Composer (you)</label>
          <input id="name" name="name" required autocomplete="name" />
        </div>
        <div class="field">
          <label for="email">Postal address (email)</label>
          <input id="email" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="field">
          <label for="sport">Sport · program</label>
          <input id="sport" name="sport" placeholder="e.g. Figure Skating · Free" required />
        </div>
        <div class="field">
          <label for="length">Program length</label>
          <input id="length" name="length" placeholder="e.g. 04:00" required />
        </div>
        <div class="field full">
          <label for="brief">Brief</label>
          <textarea id="brief" name="brief" rows="4" placeholder="Story, references, deadline…"></textarea>
        </div>
        <button class="sp-btn sp-btn-primary" data-magnetic="0.3" type="submit">
          <span>Submit composition</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12m0 0L8 2m5 5L8 12" stroke="currentColor" stroke-width="1.4"/></svg>
        </button>
      </form>

      <aside class="cta-aside" data-reveal>
        <div class="cta-row">
          <span class="eyebrow">Email</span>
          <a href="mailto:info@sky-pulse.gr" class="cta-val display-italic">info@sky-pulse.gr</a>
        </div>
        <hr class="rule" />
        <div class="cta-row">
          <span class="eyebrow">Phone</span>
          <a href="tel:+306932669999" class="cta-val display-italic">+30 6932 669999</a>
        </div>
        <hr class="rule" />
        <div class="cta-row">
          <span class="eyebrow">Response</span>
          <span class="cta-val display-italic">within 24h</span>
        </div>
        <hr class="rule" />
        <div class="cta-row">
          <span class="eyebrow">Studio hours</span>
          <span class="cta-val display-italic">Mon — Sat · 10 → 20</span>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .cta-title { font-size: clamp(4rem, 12vw, 12rem); margin: 2rem 0 1.5rem; line-height: 0.9; color: #0E0E0E; }
  .cta-sub { font-size: clamp(1.4rem, 2.2vw, 2.2rem); color: #5C564A; max-width: 32ch; margin: 0 0 2rem; }
  .cta-staff { margin: 1rem 0 3rem; }
  .cta-grid { display: grid; grid-template-columns: 1fr; gap: 4rem; align-items: start; }
  @media (min-width: 1000px) { .cta-grid { grid-template-columns: 1.3fr 1fr; gap: 5rem; } }

  .cta-form { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .cta-form .field.full { grid-column: 1 / -1; }
  .cta-form label {
    display: block;
    color: #5C564A;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .cta-form input,
  .cta-form textarea {
    width: 100%;
    background: transparent;
    color: #0E0E0E;
    border: 0;
    border-bottom: 1px solid #0E0E0E;
    padding: 0.75rem 0;
    font-family: "Newsreader", serif;
    font-size: 1.1rem;
    font-weight: 400;
    outline: none;
    transition: border-color .3s ease;
    resize: vertical;
  }
  .cta-form input:focus,
  .cta-form textarea:focus { border-color: #9B2A1F; }
  .cta-form button { grid-column: 1 / -1; justify-self: start; margin-top: 1rem; }

  .cta-aside { display: flex; flex-direction: column; gap: 1.5rem; }
  .cta-row { display: flex; flex-direction: column; gap: 0.3rem; }
  .cta-val { font-size: clamp(1.5rem, 2.5vw, 2rem); color: #0E0E0E; text-decoration: none; }
  a.cta-val:hover { color: #9B2A1F; }
</style>
