---
import Staff from "../Staff.astro";
import MusicGlyph from "../MusicGlyph.astro";

const videos = [
  { id: "1176307949", thumb: "/media/thumb-1.jpg", title: "Aurora Variations", sport: "Figure Skating · Free Program", duration: "04:00", bpm: "68–112", key: "F♯ minor", year: "2026" },
  { id: "1176307154", thumb: "/media/thumb-2.jpg", title: "Kinesis №2", sport: "Rhythmic Gymnastics · Hoop", duration: "01:30", bpm: "96–140", key: "A minor", year: "2026" },
  { id: "1176309212", thumb: "/media/thumb-3.jpg", title: "The Silent Orbit", sport: "Artistic Gymnastics · Floor", duration: "01:20", bpm: "104–132", key: "C major", year: "2026" },
  { id: "1176465736", thumb: "/media/thumb-4.jpg", title: "Nocturne for Blade", sport: "Figure Skating · Short Program", duration: "02:50", bpm: "72–118", key: "D minor", year: "2026" },
];
const movements = ["I", "II", "III", "IV"];
---

<section id="work" class="track-wrap">
  <div class="track-header container">
    <h2 class="track-lede display" data-split>
      Four routines. One vocabulary of movement, scored four different ways.
    </h2>
    <Staff height={32} notes={["𝄞", "♩", "♪", "♫"]} />
    <span class="track-hint mono" data-reveal>↓ Scroll to advance — page-turner.</span>
  </div>

  <div class="track-viewport" data-track>
    <div class="track-inner" data-track-inner>
      {videos.map((v, i) => (
        <article class="video-tile" data-vimeo={v.id} aria-label={`Play ${v.title}`}>
          <div class="tile-rule">
            <span class="tile-mvt opus">Mvt. {movements[i]}.</span>
            <hr class="rule rule-ink" />
            <span class="mono">№ 0{i + 1}</span>
          </div>

          <figure class="halftone">
            <img src={v.thumb} alt={v.title} loading={i < 2 ? "eager" : "lazy"} />
            <div class="tile-play">
              <svg width="22" height="22" viewBox="0 0 22 22"><path d="M6 3v16l14-8L6 3z" fill="currentColor"/></svg>
              <span>Play</span>
            </div>
          </figure>

          <div class="tile-meta">
            <h3 class="tile-title display-italic">{v.title}</h3>
            <dl class="tile-data">
              <div><dt>Sport</dt><dd>{v.sport}</dd></div>
              <div><dt>Runtime</dt><dd>{v.duration}</dd></div>
              <div><dt>Tempo</dt><dd><MusicGlyph glyph="quarter" size="0.95em" color="#0E0E0E" inline /> = {v.bpm}</dd></div>
              <div><dt>Key</dt><dd>{v.key}</dd></div>
            </dl>
          </div>
        </article>
      ))}

      <div class="track-end">
        <Staff height={64} notes={["𝄐"]} />
        <p class="display-italic">Fine. The next movement could be yours.</p>
        <a class="sp-btn" href="#contact" data-magnetic="0.4">Submit a brief</a>
      </div>
    </div>
  </div>
</section>

<style>
  .track-wrap { padding-top: 5rem; background: #F1ECDE; }
  .track-header { padding-bottom: 3rem; display: flex; flex-direction: column; gap: 1.5rem; }
  .track-lede {
    font-size: clamp(2rem, 4vw, 3.8rem);
    max-width: 22ch;
    margin: 0;
    color: #0E0E0E;
  }
  .track-hint { color: #5C564A; letter-spacing: 0.3em; }

  .track-viewport {
    overflow: hidden;
    height: 100vh;
    height: 100svh;
    display: flex;
    align-items: center;
  }
  .track-inner {
    display: flex;
    gap: 4rem;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
    width: max-content;
    align-items: center;
  }
  @media (max-width: 899px) {
    .track-viewport { height: auto; display: block; }
    .track-inner { flex-direction: column; width: 100%; padding-bottom: 5rem; }
  }

  .video-tile {
    width: min(85vw, 720px);
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  @media (max-width: 899px) { .video-tile { width: 100%; } }

  .tile-rule {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
  }
  .tile-mvt { font-size: 1.1rem; }

  .video-tile figure { position: relative; margin: 0; aspect-ratio: 16 / 10; overflow: hidden; }
  .video-tile img { width: 100%; height: 100%; object-fit: cover; transition: transform .6s ease; }
  .video-tile:hover img { transform: scale(1.04); }

  .tile-play {
    position: absolute;
    inset: auto 0 1rem auto;
    margin-right: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    background: #F1ECDE;
    color: #0E0E0E;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .tile-meta { display: flex; flex-direction: column; gap: 0.6rem; }
  .tile-title {
    font-size: clamp(1.6rem, 2.6vw, 2.2rem);
    margin: 0;
    color: #0E0E0E;
  }
  .tile-data {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.4rem 1.25rem;
    margin: 0.3rem 0 0;
  }
  .tile-data div { display: flex; flex-direction: column; gap: 0.15rem; }
  .tile-data dt {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #5C564A;
    margin: 0;
  }
  .tile-data dd { margin: 0; font-size: 0.95rem; color: #0E0E0E; }

  .track-end {
    width: min(70vw, 520px);
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
    align-self: center;
    border-left: 1px solid #C9C0A8;
    padding-left: 3rem;
    margin-right: 4rem;
  }
  .track-end p {
    font-size: clamp(2rem, 3.5vw, 3rem);
    margin: 0;
    color: #0E0E0E;
  }
  @media (max-width: 899px) {
    .track-end { width: 100%; border-left: 0; padding-left: 0; padding-top: 2rem; border-top: 1px solid #C9C0A8; }
  }
</style>
