---
import Staff from "../Staff.astro";
import MusicGlyph from "../MusicGlyph.astro";
import { pick, localeUrl, type Lang } from "../../i18n/strings";

interface Props { lang?: Lang; }
const { lang = "el" } = Astro.props;
const t = pick(lang);
const s = t.work;
const movements = ["I", "II", "III", "IV"];
---

<section id="work" class="section work-section">
  <div class="container">
    <h2 class="work-lede display" data-split>
      {s.lede}
    </h2>
    <Staff height={32} notes={["𝄞", "♩", "♪", "♫"]} />

    <div class="work-grid">
      {s.videos.map((v, i) => (
        <article class="video-tile" data-vimeo={v.id} aria-label={`${s.playLabel} ${v.title}`}>
          <div class="tile-rule">
            <span class="tile-mvt opus">{s.mvtLabel} {movements[i]}.</span>
            <hr class="rule rule-ink" />
            <span class="mono">{s.numLabel} 0{i + 1}</span>
          </div>

          <figure class="halftone">
            <img src={v.thumb} alt={v.title} loading={i < 2 ? "eager" : "lazy"} />
            <div class="tile-play">
              <svg width="22" height="22" viewBox="0 0 22 22"><path d="M6 3v16l14-8L6 3z" fill="currentColor"/></svg>
              <span>{s.playLabel}</span>
            </div>
          </figure>

          <div class="tile-meta">
            <h3 class="tile-title display-italic">{v.title}</h3>
            <dl class="tile-data">
              <div><dt>{s.sportLabel}</dt><dd>{v.sport}</dd></div>
              <div><dt>{s.runtimeLabel}</dt><dd>{v.duration}</dd></div>
              <div><dt>{s.tempoLabel}</dt><dd><MusicGlyph glyph="quarter" size="0.95em" color="#0E0E0E" inline /> = {v.bpm}</dd></div>
              <div><dt>{s.keyLabel}</dt><dd>{v.key}</dd></div>
            </dl>
          </div>
        </article>
      ))}
    </div>

    <div class="work-end" data-reveal>
      <Staff height={64} notes={["𝄐"]} />
      <p class="display-italic">{s.endFine}</p>
      <a class="sp-btn" href={localeUrl(lang, "/contact")} data-magnetic="0.4">{s.endCta}</a>
    </div>
  </div>
</section>

<style>
  .work-section { background: #F1ECDE; }
  .work-lede {
    font-size: clamp(2rem, 4vw, 3.8rem);
    max-width: 22ch;
    margin: 0 0 1.5rem;
    color: #0E0E0E;
  }

  .work-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-top: 3rem;
  }
  @media (min-width: 700px) {
    .work-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .video-tile {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .tile-rule {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
  }
  .tile-mvt { font-size: 1.1rem; }

  .video-tile figure { position: relative; margin: 0; aspect-ratio: 16 / 10; overflow: hidden; }
  .video-tile img { width: 100%; height: 100%; object-fit: cover; transition: transform .6s ease; }
  .video-tile:hover img { transform: scale(1.04); }

  .tile-play {
    position: absolute;
    inset: auto 0 1rem auto;
    margin-right: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    background: #F1ECDE;
    color: #0E0E0E;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .tile-meta { display: flex; flex-direction: column; gap: 0.6rem; }
  .tile-title {
    font-size: clamp(1.6rem, 2.6vw, 2.2rem);
    margin: 0;
    color: #0E0E0E;
  }
  .tile-data {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.4rem 1.25rem;
    margin: 0.3rem 0 0;
  }
  @media (min-width: 700px) {
    .tile-data { grid-template-columns: repeat(4, 1fr); }
  }
  .tile-data div { display: flex; flex-direction: column; gap: 0.15rem; }
  .tile-data dt {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #6C6E70;
    margin: 0;
  }
  .tile-data dd { margin: 0; font-size: 0.95rem; color: #0E0E0E; }

  .work-end {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 520px;
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid #C9C0A8;
  }
  .work-end p {
    font-size: clamp(2rem, 3.5vw, 3rem);
    margin: 0;
    color: #0E0E0E;
  }
</style>
