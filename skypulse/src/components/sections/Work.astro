---
import Staff from "../Staff.astro";
import MusicGlyph from "../MusicGlyph.astro";
import { pick, localeUrl, type Lang } from "../../i18n/strings";

interface Props { lang?: Lang; }
const { lang = "el" } = Astro.props;
const t = pick(lang);
const s = t.work;
const movements = ["I", "II", "III", "IV"];
---

<section id="work" class="section work-section">
  <div class="container">
    <h2 class="work-lede display" data-split>
      {s.lede}
    </h2>
    <Staff height={32} notes={["𝄞", "♩", "♪", "♫"]} />

    <div class="work-list">
      {s.videos.map((v, i) => (
        <article class={`work-item ${i % 2 === 1 ? "work-item--reverse" : ""}`} data-reveal>
          <div class="work-item-video" data-vimeo={v.id}>
            <figure class="halftone">
              <img src={v.thumb} alt={v.title} loading={i < 2 ? "eager" : "lazy"} />
              <div class="tile-play">
                <svg width="22" height="22" viewBox="0 0 22 22"><path d="M6 3v16l14-8L6 3z" fill="currentColor"/></svg>
                <span>{s.playLabel}</span>
              </div>
            </figure>
          </div>

          <div class="work-item-text">
            <span class="mono work-item-meta">
              {s.mvtLabel} {movements[i]}. — {v.sport} — {v.duration} — <MusicGlyph glyph="quarter" size="0.9em" color="#0E0E0E" inline /> = {v.bpm}
            </span>
            <h3 class="display-italic work-item-title">{v.title}</h3>
            <p class="body-serif work-item-desc">{v.desc}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="work-end" data-reveal>
      <Staff height={64} notes={["𝄐"]} />
      <p class="display-italic">{s.endFine}</p>
      <a class="sp-btn" href={localeUrl(lang, "/contact")} data-magnetic="0.4">{s.endCta}</a>
    </div>
  </div>
</section>

<style>
  .work-section { background: #F1ECDE; }
  .work-lede {
    font-size: clamp(2rem, 4vw, 3.8rem);
    max-width: 22ch;
    margin: 0 0 1.5rem;
    color: #0E0E0E;
  }

  .work-list {
    display: flex;
    flex-direction: column;
    gap: 5rem;
    margin-top: 4rem;
  }

  .work-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 800px) {
    .work-item { grid-template-columns: 1.2fr 1fr; gap: 4rem; }
    .work-item--reverse { grid-template-columns: 1fr 1.2fr; }
    .work-item--reverse .work-item-video { order: 2; }
    .work-item--reverse .work-item-text { order: 1; }
  }

  .work-item-video { position: relative; }
  .work-item-video figure {
    position: relative;
    margin: 0;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }
  .work-item-video img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform .6s ease;
  }
  .work-item-video:hover img { transform: scale(1.04); }

  .tile-play {
    position: absolute;
    inset: auto 0 1rem auto;
    margin-right: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    background: #F1ECDE;
    color: #0E0E0E;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .work-item-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .work-item-meta { color: #6C6E70; line-height: 1.6; }
  .work-item-title {
    font-size: clamp(2rem, 3.5vw, 3.5rem);
    margin: 0;
    color: #0E0E0E;
  }
  .work-item-desc {
    color: #6C6E70;
    max-width: 42ch;
    margin: 0;
  }

  .work-end {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 520px;
    margin-top: 5rem;
    padding-top: 3rem;
    border-top: 1px solid #C9C0A8;
  }
  .work-end p {
    font-size: clamp(2rem, 3.5vw, 3rem);
    margin: 0;
    color: #0E0E0E;
  }
</style>
