---
import Staff from "../Staff.astro";
import { pick, type Lang } from "../../i18n/strings";

interface Props { lang?: Lang; }
const { lang = "el" } = Astro.props;
const t = pick(lang);
const s = t.manifesto;
---

<section class="section manifesto">
  <div class="container">
    <Staff height={32} class="manifesto-staff-top" />

    <article class="manifesto-grid">
      <aside class="manifesto-gr" data-reveal>
        <p class="manifesto-gr-text body-serif dropcap">
          {s.gr.pre}<em>{s.gr.em}</em>{s.gr.post}
        </p>
      </aside>

      <blockquote class="manifesto-en">
        <p class="display-italic" data-split>
          {s.en}
        </p>
      </blockquote>
    </article>

    <hr class="rule rule-sanguine" />
    <div class="manifesto-foot" data-reveal>
      <span class="mono">{s.signed}</span>
      <span class="opus">{s.ref}</span>
    </div>
  </div>
</section>

<style>
  .manifesto-staff-top { margin: 2.5rem 0 3.5rem; }
  .manifesto-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
  }
  @media (min-width: 1000px) {
    .manifesto-grid { grid-template-columns: 1fr 1.6fr; gap: 4.5rem; }
  }
  .manifesto-gr { display: flex; flex-direction: column; gap: 1rem; }
  .manifesto-gr-text { color: #6C6E70; }
  .manifesto-gr-text em { color: #0E0E0E; font-style: italic; font-weight: 500; }
  .manifesto-en { margin: 0; display: flex; flex-direction: column; gap: 1rem; }
  .manifesto-en p {
    font-size: clamp(1.7rem, 3vw, 3.3rem);
    margin: 0;
    color: #0E0E0E;
    line-height: 1.1;
  }
  .manifesto-foot {
    display: flex;
    justify-content: space-between;
    padding-top: 1.5rem;
    color: #6C6E70;
  }
</style>
