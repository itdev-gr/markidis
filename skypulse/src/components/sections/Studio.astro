---
import Staff from "../Staff.astro";
---

<section id="studio" class="section studio">
  <div class="container">
    <span class="opus-mark" data-reveal>
      <span class="opus-num">Opus VI.</span>
      <span>Studio — the craft</span>
    </span>

    <Staff height={32} class="studio-staff" />

    <div class="studio-grid">
      <figure class="studio-img halftone">
        <img src="/media/contact.jpg" alt="Sky Pulse studio" loading="lazy" />
        <figcaption class="mono">Plate I. — Studio A · Athens</figcaption>
      </figure>

      <div class="studio-copy">
        <h2 class="display" data-split>
          Every composition is individually crafted — orchestration, production, mix, master.
        </h2>

        <div class="studio-stats">
          <div>
            <span class="display stat-num" data-count="148">0</span>
            <span class="eyebrow">Programs scored</span>
          </div>
          <div>
            <span class="display stat-num" data-count="37">0</span>
            <span class="eyebrow">National podiums</span>
          </div>
          <div>
            <span class="display stat-num" data-count="12">0</span>
            <span class="eyebrow">Countries</span>
          </div>
        </div>

        <ul class="studio-tools">
          <li><span class="mono">DAW</span> Pro Tools · Logic Pro · Cubase</li>
          <li><span class="mono">ORCHESTRA</span> Spitfire · VSL · Cinesamples</li>
          <li><span class="mono">MASTER</span> iZotope Ozone · FabFilter Pro-L 2</li>
          <li><span class="mono">DELIVERY</span> 48 kHz / 24-bit · broadcast-ready WAV</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .studio-staff { margin: 2rem 0 3rem; }
  .studio-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    margin-top: 1rem;
    align-items: start;
  }
  @media (min-width: 1000px) { .studio-grid { grid-template-columns: 1.05fr 1fr; gap: 5rem; } }

  .studio-img { position: relative; margin: 0; aspect-ratio: 3 / 4; overflow: hidden; background: #E7DEC9; }
  .studio-img img { width: 100%; height: 100%; object-fit: cover; }
  .studio-img figcaption {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    color: #0E0E0E;
    background: #F1ECDE;
    padding: 0.5rem 0.8rem;
  }

  .studio-copy { display: flex; flex-direction: column; gap: 2.5rem; }
  .studio-copy h2 { font-size: clamp(1.8rem, 2.6vw, 2.6rem); margin: 0; line-height: 1.1; color: #0E0E0E; }

  .studio-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    border-top: 1px solid #0E0E0E;
    border-bottom: 1px solid #0E0E0E;
    padding: 2rem 0;
  }
  .stat-num {
    font-family: "Newsreader", serif;
    font-style: italic;
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: #9B2A1F;
    display: block;
    line-height: 1;
    margin-bottom: 0.4rem;
  }

  .studio-tools { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.85rem; color: #5C564A; }
  .studio-tools .mono { display: inline-block; min-width: 8.5ch; color: #9B2A1F; }
</style>
