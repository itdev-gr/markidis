---
import Staff from "../Staff.astro";
import MusicGlyph from "../MusicGlyph.astro";
import { pick, localeUrl, type Lang } from "../../i18n/strings";

interface Props { lang?: Lang; }
const { lang = "el" } = Astro.props;
const t = pick(lang);
const s = t.overture;
---

<section class="hero section">
  <canvas id="hero-aurora" class="hero-aurora"></canvas>

  <div class="container hero-inner">
    <h1 class="hero-title display" data-split>
      {s.title}
    </h1>

    <div class="hero-staff">
      <Staff height={88} notes={["𝄞", "♩", "♪", "♫", "𝄐", "𝄋"]} />
    </div>

    <p class="hero-italic display-italic">
      {s.italic.pre} <em>{s.italic.em}</em>{s.italic.post}
    </p>

    <div class="hero-meta">
      <div>
        <span class="eyebrow">{s.tempoLabel}</span>
        <span class="hero-meta-val"><MusicGlyph glyph="quarter" size="1.1em" color="#1A1A2E" inline /> {s.tempoValuePrefix}</span>
      </div>
      <div>
        <span class="eyebrow">{s.keyLabel}</span>
        <span class="hero-meta-val">{s.keyValue}</span>
      </div>
      <div>
        <span class="eyebrow">{s.composedLabel}</span>
        <span class="hero-meta-val">{s.composedValue}</span>
      </div>
    </div>

    <div class="hero-cta">
      <a class="sp-btn sp-btn-primary" data-magnetic="0.35" href={localeUrl(lang, "/contact")}>
        <span>{s.ctaScore}</span>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12m0 0L8 2m5 5L8 12" stroke="currentColor" stroke-width="1.4"/></svg>
      </a>
      <a class="sp-link" href={localeUrl(lang, "/work")} data-magnetic="0.2">{s.ctaWatch}</a>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";

  function initHeroAurora() {
    const canvas = document.getElementById("hero-aurora") as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let w = 0, h = 0;

    function resize() {
      const hero = canvas!.closest(".hero") as HTMLElement;
      w = hero.offsetWidth;
      h = hero.offsetHeight;
      canvas!.width = w * dpr;
      canvas!.height = h * dpr;
      canvas!.style.width = w + "px";
      canvas!.style.height = h + "px";
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resize();
    window.addEventListener("resize", resize);

    const orbs = [
      { x: 0.15, y: 0.2,  r: 0.38, color: [91, 62, 138],  alpha: 0.12 },
      { x: 0.75, y: 0.35, r: 0.45, color: [139, 107, 175], alpha: 0.09 },
      { x: 0.5,  y: 0.8,  r: 0.35, color: [196, 166, 224], alpha: 0.07 },
      { x: 0.85, y: 0.75, r: 0.28, color: [139, 107, 175], alpha: 0.10 },
    ];

    const state = orbs.map(o => ({
      x: o.x * w,
      y: o.y * h,
      r: o.r * Math.max(w, h),
      alpha: o.alpha,
      baseX: o.x,
      baseY: o.y,
      baseR: o.r,
      color: o.color,
    }));

    // GSAP breathing timelines — each orb drifts and pulses independently
    state.forEach((s, i) => {
      const dur = 6 + i * 2.5;
      const drift = 0.08 + i * 0.03;

      // horizontal drift
      gsap.to(s, {
        x: `+=${w * drift}`,
        duration: dur,
        ease: "sine.inOut",
        yoyo: true,
        repeat: -1,
      });

      // vertical drift
      gsap.to(s, {
        y: `+=${h * drift * 0.6}`,
        duration: dur * 1.3,
        ease: "sine.inOut",
        yoyo: true,
        repeat: -1,
        delay: i * 0.8,
      });

      // pulse (scale breathing)
      gsap.to(s, {
        r: s.r * (1.15 + i * 0.05),
        duration: dur * 0.7,
        ease: "sine.inOut",
        yoyo: true,
        repeat: -1,
        delay: i * 0.5,
      });

      // alpha breathing
      gsap.to(s, {
        alpha: s.alpha * (1.4 + i * 0.15),
        duration: dur * 0.5,
        ease: "sine.inOut",
        yoyo: true,
        repeat: -1,
        delay: i * 1.2,
      });
    });

    function draw() {
      ctx!.clearRect(0, 0, w, h);
      for (const s of state) {
        const grad = ctx!.createRadialGradient(s.x, s.y, 0, s.x, s.y, s.r);
        grad.addColorStop(0, `rgba(${s.color[0]},${s.color[1]},${s.color[2]},${s.alpha})`);
        grad.addColorStop(0.5, `rgba(${s.color[0]},${s.color[1]},${s.color[2]},${s.alpha * 0.4})`);
        grad.addColorStop(1, `rgba(${s.color[0]},${s.color[1]},${s.color[2]},0)`);
        ctx!.fillStyle = grad;
        ctx!.beginPath();
        ctx!.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx!.fill();
      }
      requestAnimationFrame(draw);
    }
    draw();
  }

  document.addEventListener("DOMContentLoaded", initHeroAurora);
</script>

<style>
  .hero {
    padding: 11rem 0 6rem;
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .hero-aurora {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }
  .hero-inner {
    display: grid;
    gap: 2.5rem;
    position: relative;
    z-index: 1;
  }
  .hero-title {
    font-size: clamp(3.4rem, 11vw, 11rem);
    margin: 0;
    color: #1A1A2E;
    max-width: 18ch;
  }
  .hero-staff { margin: 0.5rem 0; opacity: 0.85; }
  .hero-italic {
    font-size: clamp(1.4rem, 2.4vw, 2.2rem);
    color: #8E8E9F;
    max-width: 36ch;
    margin: 0;
  }
  .hero-italic em { color: #8B6BAF; font-style: italic; font-weight: 500; }
  .hero-meta {
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: 2.5rem;
    justify-content: start;
    border-top: 1px solid #E0D8EC;
    border-bottom: 1px solid #E0D8EC;
    padding: 1.5rem 0;
  }
  .hero-meta div { display: flex; flex-direction: column; gap: 0.4rem; }
  .hero-meta-val {
    font-family: "Newsreader", serif;
    font-style: italic;
    font-size: 1.4rem;
    color: #1A1A2E;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 2rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-aurora { display: none; }
  }
</style>
