---
import Staff from "../Staff.astro";
import MusicGlyph from "../MusicGlyph.astro";
---

<section class="hero section">
  <div class="container hero-inner">
    <h1 class="hero-title display" data-split>
      The sound of your movement.
    </h1>

    <div class="hero-staff">
      <Staff height={88} notes={["𝄞", "♩", "♪", "♫", "𝄐", "𝄋"]} />
    </div>

    <p class="hero-italic display-italic">
      bespoke music, composed for <em>the athlete</em>.
    </p>

    <div class="hero-meta">
      <div>
        <span class="eyebrow">Tempo</span>
        <span class="hero-meta-val"><MusicGlyph glyph="quarter" size="1.1em" color="#0E0E0E" inline /> = 72</span>
      </div>
      <div>
        <span class="eyebrow">Key</span>
        <span class="hero-meta-val">D minor · espressivo</span>
      </div>
      <div>
        <span class="eyebrow">Composed in</span>
        <span class="hero-meta-val">Athens · Greece</span>
      </div>
    </div>

    <div class="hero-cta">
      <a class="sp-btn sp-btn-primary" data-magnetic="0.35" href="#contact">
        <span>Score a routine</span>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12m0 0L8 2m5 5L8 12" stroke="currentColor" stroke-width="1.4"/></svg>
      </a>
      <a class="sp-link" href="#work" data-magnetic="0.2">View the partitura ↓</a>
    </div>
  </div>
</section>

<style>
  .hero { padding: 11rem 0 6rem; min-height: 100vh; display: flex; align-items: center; }
  .hero-inner { display: grid; gap: 2.5rem; }
  .hero-opus { color: #5C564A; }
  .hero-title {
    font-size: clamp(3.4rem, 11vw, 11rem);
    margin: 0;
    color: #0E0E0E;
    max-width: 18ch;
  }
  .hero-staff { margin: 0.5rem 0; opacity: 0.85; }
  .hero-italic {
    font-size: clamp(1.4rem, 2.4vw, 2.2rem);
    color: #5C564A;
    max-width: 36ch;
    margin: 0;
  }
  .hero-italic em { color: #9B2A1F; font-style: italic; }
  .hero-meta {
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: 2.5rem;
    justify-content: start;
    border-top: 1px solid #C9C0A8;
    border-bottom: 1px solid #C9C0A8;
    padding: 1.5rem 0;
  }
  .hero-meta div { display: flex; flex-direction: column; gap: 0.4rem; }
  .hero-meta-val {
    font-family: "Newsreader", serif;
    font-style: italic;
    font-size: 1.4rem;
    color: #0E0E0E;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 2rem;
  }
</style>
