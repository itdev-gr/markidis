---
import Staff from "../Staff.astro";
import { pick, type Lang } from "../../i18n/strings";

interface Props { lang?: Lang; }
const { lang = "el" } = Astro.props;
const t = pick(lang);
const quotes = t.testimonials;
---

<section class="section testimonials sp-glow">
  <div class="container">
    <Staff height={32} class="test-staff" />

    <div class="test-grid">
      {quotes.map((q) => (
        <figure class="test-card" data-reveal>
          <blockquote class="display-italic test-q">“{q.q}”</blockquote>
          <figcaption><span class="mono">— {q.a}</span></figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .test-staff { margin: 2rem 0 3rem; }
  .test-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid #1A1A2E;
    border-bottom: 1px solid #1A1A2E;
  }
  @media (min-width: 900px) { .test-grid { grid-template-columns: repeat(3, 1fr); } }
  .test-card {
    padding: 3rem 2rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
    border-right: 1px solid #E0D8EC;
    min-height: 320px;
    transition: background .4s ease;
  }
  .test-card:last-child { border-right: 0; }
  .test-card:hover { background: #F3EEF8; }
  .test-q { font-size: clamp(1.4rem, 2.1vw, 1.85rem); color: #1A1A2E; margin: 0; line-height: 1.25; }
  .test-card figcaption { color: #8E8E9F; }
</style>
