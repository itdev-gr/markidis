---
import Staff from "../Staff.astro";
import { pick, type Lang } from "../../i18n/strings";

interface Props { lang?: Lang; }
const { lang = "el" } = Astro.props;
const t = pick(lang);
const s = t.process;
---

<section id="process" class="section process">
  <div class="container">
    <h2 class="proc-lede display" data-split>{s.lede}</h2>
    <Staff height={32} class="proc-staff" />

    <ol class="proc-list">
      {s.steps.map((p) => (
        <li class="proc-step" data-reveal>
          <span class="proc-num opus">{s.mvtLabel} {p.n}.</span>
          <div class="proc-body">
            <h3 class="display-italic">{p.t}</h3>
            <p class="body-serif">{p.d}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .proc-lede { font-size: clamp(2rem, 4vw, 3.6rem); margin: 1.5rem 0; max-width: 16ch; color: #0E0E0E; }
  .proc-staff { margin: 1rem 0 1rem; }
  .proc-list { list-style: none; padding: 0; margin: 2rem 0 0; display: flex; flex-direction: column; }
  .proc-step {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 2rem;
    align-items: start;
    padding: 2.25rem 0;
    border-top: 1px solid #C9C0A8;
    transition: background .4s ease;
  }
  .proc-step:last-child { border-bottom: 1px solid #C9C0A8; }
  .proc-step:hover { background: rgba(193, 39, 45, 0.05); }
  .proc-num { font-size: 1.5rem; }
  .proc-body { max-width: 60ch; }
  .proc-body h3 { font-size: clamp(2rem, 3.5vw, 3rem); margin: 0 0 1rem; color: #0E0E0E; }
  .proc-body p { color: #6C6E70; margin: 0; }
</style>
