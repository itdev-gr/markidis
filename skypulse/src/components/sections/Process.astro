---
import Staff from "../Staff.astro";
const process = [
  { n: "I",   t: "Brief",  d: "Athlete, coach, program, story, references. We listen for the silence before the music." },
  { n: "II",  t: "Sketch", d: "Themes, motifs, tempo map charted to choreography. A score before a sound." },
  { n: "III", t: "Record", d: "Session musicians, strings, percussion, vocalists — or all-in-the-box. Whatever the piece requires." },
  { n: "IV",  t: "Mix",    d: "Arena-ready. Translated for live PA, broadcast compression, and the rink's reverb." },
  { n: "V",   t: "Master", d: "ISU/FIG compliant, LUFS-tuned, deliverable in minutes before a deadline." },
];
---

<section id="process" class="section process">
  <div class="container">
    <h2 class="proc-lede display" data-split>Five movements. One score.</h2>
    <Staff height={32} class="proc-staff" />

    <ol class="proc-list">
      {process.map((p) => (
        <li class="proc-step" data-reveal>
          <span class="proc-num opus">Mvt. {p.n}.</span>
          <div class="proc-body">
            <h3 class="display-italic">{p.t}</h3>
            <p class="body-serif">{p.d}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .proc-lede { font-size: clamp(2rem, 4vw, 3.6rem); margin: 1.5rem 0; max-width: 16ch; color: #0E0E0E; }
  .proc-staff { margin: 1rem 0 1rem; }
  .proc-list { list-style: none; padding: 0; margin: 2rem 0 0; display: flex; flex-direction: column; }
  .proc-step {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 2rem;
    align-items: start;
    padding: 2.25rem 0;
    border-top: 1px solid #C9C0A8;
    transition: background .4s ease;
  }
  .proc-step:last-child { border-bottom: 1px solid #C9C0A8; }
  .proc-step:hover { background: rgba(155, 42, 31, 0.04); }
  .proc-num { font-size: 1.5rem; }
  .proc-body { max-width: 60ch; }
  .proc-body h3 { font-size: clamp(2rem, 3.5vw, 3rem); margin: 0 0 1rem; color: #0E0E0E; }
  .proc-body p { color: #5C564A; margin: 0; }
</style>
