---
interface Props {
  glyph: "treble" | "bass" | "quarter" | "eighth" | "beam" | "fermata" | "segno" | "coda" | "sharp" | "flat";
  size?: string;     // CSS font-size value
  color?: string;    // CSS color
  inline?: boolean;
}
const { glyph, size = "1.4em", color = "#9B2A1F", inline = true } = Astro.props;
const map: Record<Props["glyph"], string> = {
  treble: "𝄞",
  bass: "𝄢",
  quarter: "♩",
  eighth: "♪",
  beam: "♫",
  fermata: "𝄐",
  segno: "𝄋",
  coda: "𝄌",
  sharp: "♯",
  flat: "♭",
};
const Tag = inline ? "span" : "div";
---
<Tag class="sp-glyph" style={`font-size:${size};color:${color}`} aria-hidden="true">{map[glyph]}</Tag>

<style>
  .sp-glyph {
    font-family: "Newsreader", serif;
    font-style: italic;
    font-weight: 300;
    line-height: 1;
    display: inline-block;
  }
</style>
