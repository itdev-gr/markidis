---
import { pick, localeUrl, type Lang } from "../i18n/strings";

interface Props {
  lang?: Lang;
  path?: string;
}
const { lang = "el", path = "/" } = Astro.props;
const t = pick(lang);
const u = (p: string) => localeUrl(lang, p);
const home = u("/");
---

<header class="sp-header">
  <div class="sp-header-inner">
    <a href={home} class="sp-logo" aria-label="Sky Pulse — home">
      <img src="/media/logo.svg" alt="Sky Pulse" width="176" height="56" />
    </a>

    <nav class="sp-nav" aria-label="Primary">
      <a href={u("/work")}    class="sp-link">{t.nav.work}</a>
      <a href={u("/process")} class="sp-link">{t.nav.process}</a>
      <a href={u("/studio")}  class="sp-link">{t.nav.studio}</a>
      <a href={u("/contact")} class="sp-link">{t.nav.contact}</a>
    </nav>

    <div class="sp-header-meta">
      <div class="sp-lang" role="group" aria-label="Language">
        <a href={localeUrl("el", path)} class={`sp-lang-opt ${lang === "el" ? "is-active" : ""}`} aria-current={lang === "el" ? "true" : undefined}>GR</a>
        <span class="sp-lang-sep" aria-hidden="true">/</span>
        <a href={localeUrl("en", path)} class={`sp-lang-opt ${lang === "en" ? "is-active" : ""}`} aria-current={lang === "en" ? "true" : undefined}>EN</a>
      </div>
    </div>

    <button id="mobileMenuToggle" class="sp-burger" aria-label="Menu">
      <span></span><span></span>
    </button>
  </div>
  <hr class="rule rule-ink sp-header-rule" />
</header>

<div id="mobileMenu" class="sp-mobile">
  <nav>
    <a href={u("/work")}>{t.nav.work}</a>
    <a href={u("/process")}>{t.nav.process}</a>
    <a href={u("/studio")}>{t.nav.studio}</a>
    <a href={u("/contact")}>{t.nav.contact}</a>
  </nav>
  <div class="sp-mobile-foot">
    <a href={`mailto:${t.common.email}`}>{t.common.email}</a>
    <a href={t.common.phoneHref}>{t.common.phone}</a>
    <div class="sp-mobile-lang">
      <a href={localeUrl("el", path)} class={`sp-lang-opt ${lang === "el" ? "is-active" : ""}`}>GR</a>
      <span aria-hidden="true">/</span>
      <a href={localeUrl("en", path)} class={`sp-lang-opt ${lang === "en" ? "is-active" : ""}`}>EN</a>
    </div>
  </div>
</div>

<style>
  .sp-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px);
  }
  .sp-header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 2rem;
    max-width: 1600px;
    margin: 0 auto;
    padding: 1.5rem clamp(1.5rem, 4vw, 3rem);
  }
  .sp-logo {
    display: inline-flex;
    align-items: center;
  }
  .sp-logo img {
    height: 2.4rem;
    width: auto;
    display: block;
  }
  .sp-header :global(.sp-link) { font-size: 1rem; }
  .sp-header-meta {
    display: none;
    align-items: center;
    gap: 1.5rem;
  }
  @media (min-width: 900px) { .sp-header-meta { display: flex; } }

  .sp-lang {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    border: 1px solid #1A1A2E;
    padding: 0.35rem 0.75rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .sp-lang-opt {
    color: #1A1A2E;
    text-decoration: none;
    padding: 0.1rem 0.2rem;
    transition: color .25s ease;
  }
  .sp-lang-opt:hover { color: #8B6BAF; }
  .sp-lang-opt.is-active { color: #FFFFFF; background: #8B6BAF; }
  .sp-lang-sep { color: #E0D8EC; }

  .sp-nav { display: none; justify-content: center; gap: 3rem; }
  @media (min-width: 900px) { .sp-nav { display: flex; } }

  .sp-header-rule { opacity: 0.85; }

  .sp-burger {
    display: inline-flex;
    flex-direction: column;
    gap: 6px;
    width: 32px;
    height: 32px;
    align-items: flex-end;
    justify-content: center;
    background: transparent;
    border: 0;
    padding: 0;
  }
  .sp-burger span { display: block; width: 24px; height: 1px; background: #1A1A2E; }
  .sp-burger span:nth-child(2) { width: 16px; }
  @media (min-width: 900px) { .sp-burger { display: none; } }

  .sp-mobile {
    position: fixed; inset: 0;
    background: #FFFFFF;
    z-index: 99;
    display: none;
    flex-direction: column;
    justify-content: space-between;
    padding: 6rem 2rem 2rem;
  }
  .sp-mobile.active { display: flex; }
  .sp-mobile nav { display: flex; flex-direction: column; gap: 1.5rem; }
  .sp-mobile nav a {
    font-family: "Newsreader", serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2.2rem, 9vw, 4.5rem);
    color: #1A1A2E;
    text-decoration: none;
    letter-spacing: -0.02em;
  }
  .sp-mobile-foot {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .sp-mobile-foot a { color: #8E8E9F; text-decoration: none; }
  .sp-mobile-lang {
    display: inline-flex;
    gap: 0.5rem;
    padding-top: 0.5rem;
    color: #E0D8EC;
  }
  .sp-mobile-lang a { color: #1A1A2E; }
  .sp-mobile-lang a.is-active { color: #8B6BAF; }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const toggle = document.getElementById("mobileMenuToggle");
    const menu = document.getElementById("mobileMenu");
    if (toggle && menu) {
      toggle.addEventListener("click", () => {
        menu.classList.toggle("active");
        document.body.classList.toggle("no-scroll");
      });
      menu.querySelectorAll("a").forEach((a) =>
        a.addEventListener("click", () => {
          menu.classList.remove("active");
          document.body.classList.remove("no-scroll");
        })
      );
    }
  });
</script>
