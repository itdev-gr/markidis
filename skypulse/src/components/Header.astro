---
import MusicGlyph from "./MusicGlyph.astro";
const { lang = "el" } = Astro.props;
const t = {
  el: { work: "Έργα", process: "Διαδικασία", about: "Στούντιο", contact: "Επικοινωνία", lang: "EN" },
  en: { work: "Work", process: "Process", about: "Studio", contact: "Contact", lang: "EL" },
}[lang as "el" | "en"];
---

<header class="sp-header">
  <div class="sp-header-inner">
    <a href="/" class="wordmark" aria-label="Sky Pulse">
      <MusicGlyph glyph="treble" size="1.6em" color="#9B2A1F" /> sky<b>pulse</b>
    </a>

    <nav class="sp-nav" aria-label="Primary">
      <a href="#work" class="sp-link">{t.work}</a>
      <a href="#process" class="sp-link">{t.process}</a>
      <a href="#studio" class="sp-link">{t.about}</a>
      <a href="#contact" class="sp-link">{t.contact}</a>
    </nav>

    <div class="sp-header-meta">
      <span class="opus">Opus MMXXVI</span>
      <a class="sp-link" href={lang === "el" ? "/en" : "/"}>{t.lang}</a>
    </div>

    <button id="mobileMenuToggle" class="sp-burger" aria-label="Menu">
      <span></span><span></span>
    </button>
  </div>
  <hr class="rule rule-ink sp-header-rule" />
</header>

<div id="mobileMenu" class="sp-mobile">
  <nav>
    <a href="#work">{t.work}</a>
    <a href="#process">{t.process}</a>
    <a href="#studio">{t.about}</a>
    <a href="#contact">{t.contact}</a>
  </nav>
  <div class="sp-mobile-foot">
    <a href="mailto:info@sky-pulse.gr">info@sky-pulse.gr</a>
    <a href="tel:+306932669999">+30 6932 669999</a>
  </div>
</div>

<style>
  .sp-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(241, 236, 222, 0.92);
    backdrop-filter: blur(8px);
  }
  .sp-header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 2rem;
    max-width: 1600px;
    margin: 0 auto;
    padding: 1.5rem clamp(1.5rem, 4vw, 3rem);
  }
  .sp-header :global(.wordmark) {
    font-size: 2rem;
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
  }
  .sp-header :global(.sp-link) { font-size: 1rem; }
  .sp-header-meta {
    display: none;
    align-items: center;
    gap: 1.5rem;
  }
  .sp-header-meta :global(.opus) { font-size: 1.05rem; }
  @media (min-width: 900px) { .sp-header-meta { display: flex; } }

  .sp-nav { display: none; justify-content: center; gap: 3rem; }
  @media (min-width: 900px) { .sp-nav { display: flex; } }

  .sp-header-rule { opacity: 0.85; }

  .sp-burger {
    display: inline-flex;
    flex-direction: column;
    gap: 6px;
    width: 32px;
    height: 32px;
    align-items: flex-end;
    justify-content: center;
    background: transparent;
    border: 0;
    padding: 0;
  }
  .sp-burger span { display: block; width: 24px; height: 1px; background: #0E0E0E; }
  .sp-burger span:nth-child(2) { width: 16px; }
  @media (min-width: 900px) { .sp-burger { display: none; } }

  .sp-mobile {
    position: fixed; inset: 0;
    background: #F1ECDE;
    z-index: 99;
    display: none;
    flex-direction: column;
    justify-content: space-between;
    padding: 6rem 2rem 2rem;
  }
  .sp-mobile.active { display: flex; }
  .sp-mobile nav { display: flex; flex-direction: column; gap: 1.5rem; }
  .sp-mobile nav a {
    font-family: "Newsreader", serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2.2rem, 9vw, 4.5rem);
    color: #0E0E0E;
    text-decoration: none;
    letter-spacing: -0.02em;
  }
  .sp-mobile-foot {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .sp-mobile-foot a { color: #5C564A; text-decoration: none; }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const toggle = document.getElementById("mobileMenuToggle");
    const menu = document.getElementById("mobileMenu");
    if (toggle && menu) {
      toggle.addEventListener("click", () => {
        menu.classList.toggle("active");
        document.body.classList.toggle("no-scroll");
      });
      menu.querySelectorAll("a").forEach((a) =>
        a.addEventListener("click", () => {
          menu.classList.remove("active");
          document.body.classList.remove("no-scroll");
        })
      );
    }
  });
</script>
