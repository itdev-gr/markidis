---
interface Props {
  height?: number;     // total svg height
  notes?: string[];    // optional unicode glyphs to place along the line
  variant?: "thin" | "thick";
  class?: string;
}
const { height = 64, notes = [], variant = "thin", class: cls = "" } = Astro.props;
const stroke = variant === "thick" ? 1.5 : 1;
const lines = [0.15, 0.32, 0.5, 0.68, 0.85];
---
<svg
  class={`sp-staff ${cls}`}
  viewBox={`0 0 1200 ${height}`}
  preserveAspectRatio="none"
  width="100%"
  height={height}
  aria-hidden="true"
>
  {lines.map((p) => (
    <line x1="0" x2="1200" y1={p * height} y2={p * height} stroke="#C9C0A8" stroke-width={stroke} />
  ))}
  {notes.length > 0 && (
    <g class="sp-staff-notes" font-family="Newsreader, serif" font-style="italic" fill="#0E0E0E" font-size={height * 0.6}>
      {notes.map((n, i) => (
        <text x={`${(i + 1) * (1200 / (notes.length + 1))}`} y={height * 0.7} text-anchor="middle">{n}</text>
      ))}
    </g>
  )}
</svg>

<style>
  .sp-staff { display: block; width: 100%; }
</style>
