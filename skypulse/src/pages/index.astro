---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const videos = [
  {
    id: "1176307949",
    thumb: "/media/thumb-1.jpg",
    title: "Aurora Variations",
    sport: "Figure Skating · Free Program",
    duration: "04:00",
    bpm: "68–112",
    year: "2026",
  },
  {
    id: "1176307154",
    thumb: "/media/thumb-2.jpg",
    title: "Kinesis №2",
    sport: "Rhythmic Gymnastics · Hoop",
    duration: "01:30",
    bpm: "96–140",
    year: "2026",
  },
  {
    id: "1176309212",
    thumb: "/media/thumb-3.jpg",
    title: "The Silent Orbit",
    sport: "Artistic Gymnastics · Floor",
    duration: "01:20",
    bpm: "104–132",
    year: "2026",
  },
  {
    id: "1176465736",
    thumb: "/media/thumb-4.jpg",
    title: "Nocturne for Blade",
    sport: "Figure Skating · Short Program",
    duration: "02:50",
    bpm: "72–118",
    year: "2026",
  },
];

const disciplines = [
  { name: "Figure Skating", code: "FS", note: "ISU timing · edge-aware accents" },
  { name: "Rhythmic Gymnastics", code: "RG", note: "FIG apparatus · pulse beds for apparatus toss" },
  { name: "Artistic Gymnastics", code: "AG", note: "Floor 1:20 · tumbling-synced stingers" },
  { name: "Show Choreography", code: "SC", note: "Gala & exhibition · narrative arcs" },
  { name: "Performance Sports", code: "PS", note: "Acrobatic · cheer · synchro" },
];

const process = [
  { n: "01", t: "Brief", d: "Athlete, coach, program, story, references. We listen for the silence before the music." },
  { n: "02", t: "Sketch", d: "Themes, motifs, tempo map charted to choreography. A score before a sound." },
  { n: "03", t: "Record", d: "Session musicians, strings, percussion, vocalists — or all-in-the-box. Whatever the piece requires." },
  { n: "04", t: "Mix", d: "Arena-ready. Translated for live PA, broadcast compression, and the rink's reverb." },
  { n: "05", t: "Master", d: "ISU/FIG compliant, LUFS-tuned, deliverable in minutes before a deadline." },
];
---

<Base title="Sky Pulse — the sound of your movement" lang="el">
  <canvas id="pulse-grid" class="pulse-grid-canvas"></canvas>
  <Header lang="el" />

  <!-- ============================================================
       I. OVERTURE
       ============================================================ -->
  <section class="hero section">
    <canvas id="hero-wave" class="hero-wave"></canvas>

    <div class="container hero-inner">
      <span class="movement hero-eyebrow">
        <span class="num">I.</span>
        <span>Overture — Precision · Performance · Emotion</span>
      </span>

      <h1 class="hero-title display" data-split>
        The sound of your movement.
      </h1>

      <p class="hero-italic display-italic">
        bespoke music, composed for <em>the athlete</em>.
      </p>

      <div class="hero-meta">
        <div>
          <span class="eyebrow">Since</span>
          <span class="mono">MMXXVI</span>
        </div>
        <div>
          <span class="eyebrow">Based in</span>
          <span class="mono">Athens · GR</span>
        </div>
        <div>
          <span class="eyebrow">Composed for</span>
          <span class="mono">Ice · Carpet · Stage</span>
        </div>
      </div>

      <div class="hero-cta">
        <a class="sp-btn sp-btn-primary" data-magnetic="0.35" href="#contact">
          <span>Score a routine</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12m0 0L8 2m5 5L8 12" stroke="currentColor" stroke-width="1.4"/></svg>
        </a>
        <a class="sp-link" href="#work" data-magnetic="0.2">Watch the work</a>
      </div>
    </div>

    <div class="hero-scroll">
      <span class="eyebrow">Scroll</span>
      <div class="bpm-bar"><i></i></div>
    </div>
  </section>

  <!-- ============================================================
       II. MANIFESTO
       ============================================================ -->
  <section class="section manifesto">
    <div class="container">
      <div class="movement" data-reveal>
        <span class="num">II.</span>
        <span>Manifesto — a strategic element of performance</span>
      </div>

      <div class="manifesto-grid">
        <aside class="manifesto-gr" data-reveal>
          <span class="eyebrow">ελληνικά</span>
          <p class="display-italic">
            «Η μουσική μας δεν είναι απλώς συνοδεία — είναι <span class="amber">στρατηγικό εργαλείο απόδοσης</span>,
            σχεδιασμένο να ενισχύει την παρουσία, να προκαλεί συναίσθημα και να μετατρέπει
            κάθε εμφάνιση σε εμπειρία.»
          </p>
        </aside>

        <blockquote class="manifesto-en">
          <span class="eyebrow">english</span>
          <p class="display" data-split>
            Our music is more than accompaniment — it is a strategic element of performance,
            designed to enhance presence, evoke emotion, and transform every routine into an experience.
          </p>
        </blockquote>
      </div>

      <div class="manifesto-foot" data-reveal>
        <span class="mono">— signed, the composer</span>
        <span class="mono">№ 01 / IV</span>
      </div>
    </div>
  </section>

  <!-- ============================================================
       III. PORTFOLIO TRACK
       ============================================================ -->
  <section id="work" class="track-wrap" data-track>
    <div class="track-header container">
      <div class="movement" data-reveal>
        <span class="num">III.</span>
        <span>Selected Work — Routines · 2026</span>
      </div>
      <p class="track-lede display" data-split>
        Four routines. One vocabulary of movement, scored four different ways.
      </p>
    </div>

    <div class="track-viewport">
      <div class="track-inner" data-track-inner>
        {videos.map((v, i) => (
          <article class="video-tile" data-vimeo={v.id} aria-label={`Play ${v.title}`}>
            <figure>
              <img src={v.thumb} alt={v.title} loading={i < 2 ? "eager" : "lazy"} />
              <div class="tile-play">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path d="M8 5v14l11-7L8 5z" fill="currentColor"/>
                </svg>
              </div>
            </figure>
            <div class="tile-meta">
              <div class="tile-num mono">№ 0{i + 1}</div>
              <h3 class="tile-title display-italic">{v.title}</h3>
              <dl class="tile-data">
                <div><dt>Sport</dt><dd>{v.sport}</dd></div>
                <div><dt>Runtime</dt><dd>{v.duration}</dd></div>
                <div><dt>Tempo</dt><dd>{v.bpm} BPM</dd></div>
                <div><dt>Year</dt><dd>{v.year}</dd></div>
              </dl>
            </div>
          </article>
        ))}

        <div class="track-end">
          <span class="eyebrow">End of reel</span>
          <p class="display-italic">The next one could be yours.</p>
          <a class="sp-btn" href="#contact" data-magnetic="0.4">Start a brief</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       IV. DISCIPLINES
       ============================================================ -->
  <section class="section disciplines">
    <div class="container">
      <div class="movement" data-reveal>
        <span class="num">IV.</span>
        <span>Disciplines — written to the rulebook</span>
      </div>

      <div class="disc-grid">
        {disciplines.map((d, i) => (
          <div class="disc-card" data-reveal>
            <div class="disc-head">
              <span class="mono">{d.code}</span>
              <span class="mono">№ 0{i + 1}</span>
            </div>
            <h3 class="display">{d.name}</h3>
            <p>{d.note}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="marquee" data-marquee aria-hidden="true">
      <div class="marquee-inner" data-marquee-inner>
        <span class="display-italic">Precision</span>
        <span class="dot">✺</span>
        <span class="display-italic">Performance</span>
        <span class="dot">✺</span>
        <span class="display-italic">Emotion</span>
        <span class="dot">✺</span>
        <span class="display-italic">ο ήχος της κίνησής σου</span>
        <span class="dot">✺</span>
      </div>
    </div>
  </section>

  <!-- ============================================================
       V. PROCESS
       ============================================================ -->
  <section id="process" class="section process">
    <div class="container">
      <div class="movement" data-reveal>
        <span class="num">V.</span>
        <span>Process — brief to master, five movements</span>
      </div>

      <ol class="process-list">
        {process.map((p) => (
          <li class="process-step" data-reveal>
            <span class="process-num display">{p.n}</span>
            <div class="process-body">
              <h3 class="display-italic">{p.t}</h3>
              <p>{p.d}</p>
            </div>
            <div class="process-line"></div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============================================================
       VI. STUDIO & CRAFT
       ============================================================ -->
  <section id="studio" class="section studio">
    <div class="container">
      <div class="movement" data-reveal>
        <span class="num">VI.</span>
        <span>Studio — the craft</span>
      </div>

      <div class="studio-grid">
        <figure class="studio-img">
          <img src="/media/contact.jpg" alt="Sky Pulse studio" loading="lazy" />
          <figcaption class="mono">Studio A · Athens</figcaption>
        </figure>

        <div class="studio-copy">
          <h2 class="display" data-split>
            Every composition is individually crafted — orchestration, production, mix, master.
          </h2>

          <div class="studio-stats">
            <div>
              <span class="display stat-num" data-count="148">0</span>
              <span class="eyebrow">Programs scored</span>
            </div>
            <div>
              <span class="display stat-num" data-count="37">0</span>
              <span class="eyebrow">National podiums</span>
            </div>
            <div>
              <span class="display stat-num" data-count="12">0</span>
              <span class="eyebrow">Countries</span>
            </div>
          </div>

          <ul class="studio-tools">
            <li><span class="mono">DAW</span> Pro Tools · Logic Pro · Cubase</li>
            <li><span class="mono">ORCHESTRA</span> Spitfire · VSL · Cinesamples</li>
            <li><span class="mono">MASTER</span> iZotope Ozone · FabFilter Pro-L 2</li>
            <li><span class="mono">DELIVERY</span> 48kHz/24-bit · broadcast-ready WAV</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       VII. TESTIMONIALS
       ============================================================ -->
  <section class="section testimonials">
    <div class="container">
      <div class="movement" data-reveal>
        <span class="num">VII.</span>
        <span>Words — from coaches &amp; athletes</span>
      </div>

      <div class="test-grid">
        <figure class="test-card" data-reveal>
          <blockquote class="display-italic">
            "The music didn't just fit her routine. It wrote it."
          </blockquote>
          <figcaption>
            <span class="mono">— Head Coach · National Figure Skating Team</span>
          </figcaption>
        </figure>

        <figure class="test-card" data-reveal>
          <blockquote class="display-italic">
            "Every accent lands with her hoop. It feels composed <em>to her body</em>, not to a stopwatch."
          </blockquote>
          <figcaption>
            <span class="mono">— Senior Rhythmic Gymnast · Athens</span>
          </figcaption>
        </figure>

        <figure class="test-card" data-reveal>
          <blockquote class="display-italic">
            "Arena-ready on delivery. No post-mastering panic on competition day."
          </blockquote>
          <figcaption>
            <span class="mono">— Choreographer · Show Ensemble</span>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ============================================================
       VIII. BOOKING CTA
       ============================================================ -->
  <section id="contact" class="section cta">
    <div class="container">
      <div class="movement" data-reveal>
        <span class="num">VIII.</span>
        <span>Encore — let's score your next routine</span>
      </div>

      <h2 class="cta-title display" data-split>
        Score your next routine.
      </h2>

      <p class="cta-sub display-italic" data-reveal>
        Tell us the athlete, the sport, the deadline. We answer in 24 hours.
      </p>

      <div class="cta-grid">
        <form class="cta-form" data-reveal onsubmit="event.preventDefault(); alert('Thank you. We will be in touch within 24 hours.');">
          <div class="field">
            <label for="name">Name</label>
            <input id="name" name="name" required autocomplete="name" />
          </div>
          <div class="field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" required autocomplete="email" />
          </div>
          <div class="field">
            <label for="sport">Sport · Program</label>
            <input id="sport" name="sport" placeholder="e.g. Figure Skating · Free" required />
          </div>
          <div class="field">
            <label for="length">Program length</label>
            <input id="length" name="length" placeholder="e.g. 04:00" required />
          </div>
          <div class="field full">
            <label for="brief">Brief</label>
            <textarea id="brief" name="brief" rows="4" placeholder="Story, references, deadline…"></textarea>
          </div>
          <button class="sp-btn sp-btn-primary" data-magnetic="0.3" type="submit">
            <span>Send brief</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12m0 0L8 2m5 5L8 12" stroke="currentColor" stroke-width="1.4"/></svg>
          </button>
        </form>

        <aside class="cta-aside" data-reveal>
          <div class="cta-row">
            <span class="eyebrow">Email</span>
            <a href="mailto:info@sky-pulse.gr" class="cta-val display-italic">info@sky-pulse.gr</a>
          </div>
          <hr class="rule" />
          <div class="cta-row">
            <span class="eyebrow">Phone</span>
            <a href="tel:+306932669999" class="cta-val display-italic">+30 6932 669999</a>
          </div>
          <hr class="rule" />
          <div class="cta-row">
            <span class="eyebrow">Response</span>
            <span class="cta-val display-italic">within 24h</span>
          </div>
          <hr class="rule" />
          <div class="cta-row">
            <span class="eyebrow">Studio hours</span>
            <span class="cta-val display-italic">Mon — Sat · 10 → 20</span>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <Footer lang="el" />

  <!-- ============================================================
       Video overlay
       ============================================================ -->
  <div id="video-overlay" class="video-overlay" role="dialog" aria-modal="true">
    <button id="video-overlay-close" aria-label="Close" class="video-overlay-close">
      <svg width="22" height="22" viewBox="0 0 22 22"><path d="M2 2l18 18M20 2L2 20" stroke="currentColor" stroke-width="1.4"/></svg>
    </button>
    <div id="video-overlay-inner" class="video-overlay-inner"></div>
  </div>
</Base>

<style>
  /* ============================================================ Canvas background */
  .pulse-grid-canvas {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 0;
    opacity: 0.8;
  }

  /* ============================================================ Hero */
  .hero {
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    padding-bottom: 6rem;
    position: relative;
    overflow: hidden;
  }
  .hero-wave {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.9;
    z-index: 1;
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 2.5rem;
  }
  .hero-eyebrow { color: #B8AE92; }
  .hero-title {
    font-size: clamp(3.4rem, 11vw, 11rem);
    max-width: 16ch;
    margin: 0;
  }
  .hero-italic {
    font-size: clamp(1.2rem, 2vw, 1.75rem);
    color: #B8AE92;
    max-width: 34ch;
  }
  .hero-italic em {
    color: #E8A33D;
    font-style: italic;
  }
  .hero-meta {
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: 2rem;
    justify-content: start;
    border-top: 1px solid #3D362A;
    padding-top: 1.5rem;
  }
  .hero-meta div { display: flex; flex-direction: column; gap: 0.35rem; }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 2rem;
  }
  .hero-scroll {
    position: absolute;
    right: clamp(1.25rem, 4vw, 3rem);
    bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    z-index: 2;
  }
  .bpm-bar {
    width: 2px; height: 48px;
    background: #3D362A;
    position: relative;
    overflow: hidden;
  }
  .bpm-bar i {
    position: absolute;
    left: 0; right: 0; top: 0;
    height: 40%;
    background: linear-gradient(#E8A33D, transparent);
    animation: bpm 0.85s cubic-bezier(.5,0,.5,1) infinite;
  }
  @keyframes bpm {
    0% { transform: translateY(-100%); }
    60% { transform: translateY(150%); }
    100% { transform: translateY(150%); }
  }

  /* ============================================================ Manifesto */
  .manifesto {
    background: #1D1A14;
    position: relative;
    z-index: 2;
  }
  .manifesto-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding: 5rem 0 3rem;
  }
  @media (min-width: 900px) {
    .manifesto-grid { grid-template-columns: 0.8fr 1.2fr; gap: 4rem; }
  }
  .manifesto-gr {
    border-left: 1px solid #3D362A;
    padding-left: 2rem;
  }
  .manifesto-gr p {
    font-size: clamp(1.4rem, 2vw, 2rem);
    color: #B8AE92;
    line-height: 1.35;
  }
  .manifesto-gr .amber { color: #E8A33D; }
  .manifesto-en p {
    font-size: clamp(1.8rem, 3.2vw, 3.6rem);
    margin: 0;
    line-height: 1.08;
  }
  .manifesto-en {
    margin: 0;
    padding: 0;
  }
  .manifesto-foot {
    display: flex;
    justify-content: space-between;
    padding-top: 3rem;
    border-top: 1px solid #3D362A;
    color: #B8AE92;
  }

  /* ============================================================ Portfolio track */
  .track-wrap {
    position: relative;
    background: #1D1A14;
    z-index: 2;
    padding-top: 5rem;
  }
  .track-header {
    padding-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .track-lede {
    font-size: clamp(2rem, 4vw, 4rem);
    max-width: 20ch;
    margin: 0;
  }
  .track-viewport {
    overflow: hidden;
  }
  .track-inner {
    display: flex;
    gap: 3rem;
    padding: 0 clamp(1.25rem, 4vw, 3rem) 5rem;
    width: max-content;
  }
  @media (max-width: 899px) {
    .track-inner {
      flex-direction: column;
      width: 100%;
      padding: 0 clamp(1.25rem, 4vw, 3rem) 5rem;
    }
  }
  .video-tile {
    width: min(80vw, 640px);
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: relative;
  }
  @media (max-width: 899px) {
    .video-tile { width: 100%; }
  }
  .video-tile figure {
    position: relative;
    margin: 0;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: #26221A;
  }
  .video-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: contrast(1.02) brightness(1);
    transition: filter .6s ease, transform .6s ease;
  }
  .video-tile:hover img { filter: contrast(1.08) brightness(1.05); }
  .tile-play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: #F4ECD8;
    background: linear-gradient(180deg, rgba(8,8,12,0) 60%, rgba(8,8,12,0.7));
    opacity: 0.6;
    transition: opacity .4s ease;
  }
  .video-tile:hover .tile-play { opacity: 1; }
  .tile-play svg {
    width: 56px; height: 56px;
    border: 1px solid #F4ECD8;
    border-radius: 50%;
    padding: 14px;
    background: rgba(8,8,12,0.3);
    backdrop-filter: blur(4px);
  }
  .tile-meta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .tile-num { color: #B8AE92; }
  .tile-title {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    margin: 0;
    color: #F4ECD8;
  }
  .tile-data {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem 2rem;
    margin: 0.5rem 0 0;
  }
  .tile-data div { display: flex; flex-direction: column; gap: 0.15rem; }
  .tile-data dt {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #B8AE92;
    margin: 0;
  }
  .tile-data dd {
    font-family: "Manrope", sans-serif;
    font-size: 0.92rem;
    color: #F4ECD8;
    margin: 0;
  }

  .track-end {
    width: min(70vw, 520px);
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
    align-self: center;
    border-left: 1px solid #3D362A;
    padding-left: 3rem;
  }
  .track-end p {
    font-size: clamp(2rem, 3.5vw, 3.5rem);
    margin: 0;
  }
  @media (max-width: 899px) {
    .track-end { width: 100%; border-left: 0; padding-left: 0; padding-top: 2rem; border-top: 1px solid #3D362A; }
  }

  /* ============================================================ Disciplines */
  .disciplines { position: relative; z-index: 2; background: #1D1A14; }
  .disc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: #3D362A;
    margin-top: 4rem;
    border: 1px solid #3D362A;
  }
  @media (min-width: 700px) {
    .disc-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1100px) {
    .disc-grid { grid-template-columns: repeat(5, 1fr); }
  }
  .disc-card {
    background: #1D1A14;
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-height: 320px;
    transition: background .5s ease;
    cursor: none;
  }
  .disc-card:hover { background: #26221A; }
  .disc-head {
