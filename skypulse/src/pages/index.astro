---
import Page from "../layouts/Page.astro";
import Overture from "../components/sections/Overture.astro";
import Manifesto from "../components/sections/Manifesto.astro";
import Disciplines from "../components/sections/Disciplines.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import { pick } from "../i18n/strings";

const lang = "el";
const m = pick(lang).meta.home;
---

<Page lang={lang} path="/" title={m.title} description={m.description}>
  <Overture lang={lang} />
  <Manifesto lang={lang} />
  <Disciplines lang={lang} />
  <Testimonials lang={lang} />
</Page>
