---
import Page from "../../../layouts/Page.astro";
import Studio from "../../../components/sections/Studio.astro";
import { pick } from "../../../i18n/strings";

const lang = "en";
const m = pick(lang).meta.studio;
---

<Page lang={lang} path="/studio" title={m.title} description={m.description}>
  <div class="page-top" />
  <Studio lang={lang} />
</Page>

<style>
  .page-top { height: 6rem; }
</style>
