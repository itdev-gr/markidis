---
import Page from "../../../layouts/Page.astro";
import Work from "../../../components/sections/Work.astro";
import { pick } from "../../../i18n/strings";

const lang = "en";
const m = pick(lang).meta.work;
---

<Page lang={lang} path="/work" title={m.title} description={m.description}>
  <div class="page-top" />
  <Work lang={lang} />
</Page>

<style>
  .page-top { height: 6rem; }
</style>
